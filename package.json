{
  "name": "@mia/api-core",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "dev:docker": "nodemon",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "tsx src/services/migrate.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@mia/core-collectors": "workspace:*",
    "@mia/shared-core": "workspace:*",
    "bullmq": "^5.34.5",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pg": "^8.13.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.8",
    "nodemon": "^3.1.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}